# Optional: point the frontend at the Python backend gateway.
# When set, DRTC connects to the backend over a websocket and the in-browser
# pollers stay off. When unset, the app runs fully standalone.
#
#   VITE_DRTC_API=https://your-drtc-backend.example.com
#
# Also available: VITE_NASA_KEY for a higher NASA NeoWs rate limit (standalone
# mode only; the shared DEMO_KEY is used by default).
